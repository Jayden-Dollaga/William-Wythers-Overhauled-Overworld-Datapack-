{
  "type": "minecraft:tree",
  "config": {
    "decorators": [
      {
        "type": "minecraft:creaking_heart",
        "probability": 0.1
      }
    ],
    "foliage_placer": {
      "type": "minecraft:mega_pine_foliage_placer",
      "offset": 2,
      "radius": 1,
      "crown_height": {
        "type": "minecraft:uniform",
        "min_inclusive": 5,
        "max_inclusive": 10
      }
    },
    "foliage_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "minecraft:pale_oak_wood",
        "Properties": {
          "axis": "y"
        }
      }
    },
    "ignore_vines": true,
    "minimum_size": {
      "type": "minecraft:three_layers_feature_size",
      "limit": 1,
      "lower_size": 0,
      "middle_size": 1,
      "upper_limit": 1,
      "upper_size": 2
    },
    "trunk_placer": {
      "type": "minecraft:giant_trunk_placer",
      "base_height": 10,
      "height_rand_a": 6,
      "height_rand_b": 6
    },
    "trunk_provider": {
      "type": "minecraft:simple_state_provider",
      "state": {
        "Name": "minecraft:stripped_pale_oak_log",
        "Properties": {
          "axis": "y"
        }
      }
    },
    "below_trunk_provider": {
      "type": "minecraft:rule_based_state_provider",
      "rules": [
        {
          "if_true": {
            "type": "minecraft:not",
            "predicate": {
              "type": "minecraft:matching_block_tag",
              "tag": "minecraft:cannot_replace_below_tree_trunk"
            }
          },
          "then": {
            "type": "minecraft:simple_state_provider",
            "state": {
              "Name": "minecraft:stripped_pale_oak_log",
              "Properties": {
                "axis": "y"
              }
            }
          }
        }
      ]
    }
  }
}
